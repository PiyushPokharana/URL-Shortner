APP_NAME=
NODE_ENV=
PORT=
TRUST_PROXY=
CORS_ORIGIN=

# Railway-style URLs (preferred on Railway)
DATABASE_URL=
REDIS_URL=

POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_SSL=

REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=
REDIS_CACHE_TTL_SECONDS=3600

URL_FILTER_ENABLED=true
URL_FILTER_BLOOM_BITS=8192
URL_FILTER_BLOOM_HASHES=4

URL_CLEANUP_ENABLED=true
URL_CLEANUP_INTERVAL_SECONDS=300
URL_CLEANUP_BATCH_SIZE=1000
URL_CLEANUP_RUN_ON_STARTUP=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60

ANALYTICS_QUEUE_NAME=analytics-clicks
ANALYTICS_QUEUE_ATTEMPTS=5
ANALYTICS_QUEUE_BACKOFF_MS=1000
ANALYTICS_WORKER_CONCURRENCY=5
ANALYTICS_QUEUE_REMOVE_ON_COMPLETE=1000
ANALYTICS_QUEUE_REMOVE_ON_FAIL=5000

LOG_LEVEL=info
